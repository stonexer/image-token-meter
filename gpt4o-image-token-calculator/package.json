{
  "name": "gpt4o-image-token-calculator",
  "version": "1.0.0",
  "description": "Calculate GPT-4o image token consumption for OpenAI Vision API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openai",
    "gpt-4o",
    "gpt4",
    "vision",
    "image",
    "token",
    "calculator",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/ui": "^1.0.0",
    "esbuild": "^0.19.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/gpt4o-image-token-calculator.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/gpt4o-image-token-calculator/issues"
  },
  "homepage": "https://github.com/yourusername/gpt4o-image-token-calculator#readme"
}